       "    </tr>\n",
       "  </thead>\n",
       "  <tbody>\n",
       "    <tr>\n",
       "      <th>0</th>\n",
       "      <td>0 (ubebodd)</td>\n",
       "      <td>4207</td>\n",
       "      <td>0.0</td>\n",
       "    </tr>\n",
       "    <tr>\n",
       "      <th>1</th>\n",
       "      <td>10–50</td>\n",
       "      <td>493</td>\n",
       "      <td>13514.0</td>\n",
       "    </tr>\n",
       "    <tr>\n",
       "      <th>2</th>\n",
       "      <td>50–100</td>\n",
       "      <td>279</td>\n",
       "      <td>20395.0</td>\n",
