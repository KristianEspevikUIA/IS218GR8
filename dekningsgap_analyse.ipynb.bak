   "source": [
    "## 7. Eksport — GeoJSON for webkart\n",
    "\n",
    "Resultata vert lagra i `app/data/coverage/` og serverte via Flask-endepunkta `/api/coverage/*` til Leaflet-frontenden.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "id": "76e201bd",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-04-21T10:05:35.600645Z",
     "iopub.status.busy": "2026-04-21T10:05:35.600407Z",
     "iopub.status.idle": "2026-04-21T10:05:40.505826Z",
     "shell.execute_reply": "2026-04-21T10:05:40.503273Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✓ service_areas.geojson  (28 features, 81.1 kB)\n",
      "✓ coverage_gaps.geojson  (1 features, 12.4 kB)\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✓ risk_grid.geojson  (5439 features, 2586.4 kB)\n",
      "✓ recommendations.geojson  (10 features, 2.8 kB)\n"
     ]
    },
    {
