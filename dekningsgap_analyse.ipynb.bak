   "source": [
    "brann_path = DATA / \"brannstasjoner_cache.geojson\"\n",
    "if brann_path.exists():\n",
    "    brann = gpd.read_file(brann_path)\n",
    "else:\n",
    "    brann = gpd.GeoDataFrame(\n",
    "        [{\"brannstasjon\": \"Kristiansand hovudstasjon\", \"category\": \"brannstasjon\"}],\n",
    "        geometry=[Point(8.0012, 58.1489)], crs=WGS84,\n",
    "    )\n",
    "brann[\"category\"] = \"brannstasjon\"\n",
    "print(f\"Brannstasjonar: {len(brann)}\")\n",
    "\n",
    "landmarks = gpd.read_file(DATA / \"norwegian_landmarks.geojson\")\n",
    "landmarks_pts = landmarks[landmarks.geometry.type == \"Point\"].copy()\n",
    "print(f\"Beredskapsressursar (Point): {len(landmarks_pts)}\")\n",
    "landmarks_pts[[\"name\", \"category\"]].head(10)\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "35937c83",
   "metadata": {},
   "source": [
    "## 3. Filtrering og visualisering\n",
    "\n",
    "Vi utfører romleg filtrering (`sjoin`) for å isolere AED-ar som faktisk ligg innanfor kommunegrensa, og viser inngangsdataa på eit felles Folium-kart.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "e9037044",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-04-21T10:05:31.386898Z",
     "iopub.status.busy": "2026-04-21T10:05:31.386653Z",
     "iopub.status.idle": "2026-04-21T10:05:31.397371Z",
     "shell.execute_reply": "2026-04-21T10:05:31.395573Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "AED-ar innanfor kommunen: 5/15\n"
     ]
    }
   ],
   "source": [
    "# Romleg filtrering — AED-ar innanfor Kristiansand kommune\n",
    "aeds_i_krs = gpd.sjoin(aeds_open, kommune, how=\"inner\", predicate=\"within\")\n",
    "print(f\"AED-ar innanfor kommunen: {len(aeds_i_krs)}/{len(aeds_open)}\")\n"
   ]
  },
